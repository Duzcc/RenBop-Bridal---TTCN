# ==============================================================================
# HƯỚNG DẪN CẤU HÌNH FILE ENV CHO BACKEND (RENBOP BRIDAL)
# ==============================================================================
# Hãy sao chép nội dung file này hoặc sử dụng trực tiếp file .env này và điền các thông tin sau.

# ── 1. Cấu hình JWT (JSON Web Token) ──────────────────────────────────────────
# Khóa bí mật dùng để mã hóa và giải mã token JWT đăng nhập.
# Lưu ý: Khóa này phải dài ít nhất 256-bit (tối thiểu 32 ký tự). Hãy tự thay đổi chuỗi ngẫu nhiên.
JWT_SECRET=your_super_secret_jwt_key_must_be_at_least_32_characters_long_change_me!

# ── 2. Cấu hình Redis ─────────────────────────────────────────────────────────
# Dùng để lưu trữ session, OTP hoặc cache (nếu có). Cấu hình mặc định chạy trên localhost.
REDIS_HOST=localhost
REDIS_PORT=6379

# ── 3. Cấu hình Cơ sở dữ liệu (PostgreSQL) ────────────────────────────────────
# - DB_URL: Đường dẫn kết nối database PostgreSQL. Định dạng: jdbc:postgresql://[host]:[port]/[database_name]
# - DB_USERNAME: Tên tài khoản cơ sở dữ liệu.
# - DB_PASSWORD: Mật khẩu tài khoản cơ sở dữ liệu.
DB_URL=jdbc:postgresql://localhost:5432/renbop_bridal
DB_USERNAME=postgres
DB_PASSWORD=your_database_password

# ── 4. Cấu hình CORS & Frontend URL ───────────────────────────────────────────
# - CORS_ALLOWED_ORIGINS: Các domain frontend được phép gửi request đến backend (ngăn lỗi CORS).
# - FRONTEND_URL: Địa chỉ của frontend, dùng để sinh đường dẫn trong email (ví dụ: đặt lại mật khẩu).
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── 5. Cấu hình Email SMTP (Gửi OTP, Hóa đơn) ───────────────────────────────
# Hướng dẫn lấy SMTP_PASSWORD (Mật khẩu ứng dụng của Gmail):
# 1. Truy cập tài khoản Google của bạn -> Bảo mật (Security).
# 2. Bật Xác minh 2 bước (2-Step Verification) nếu chưa bật.
# 3. Tìm mục "Mật khẩu ứng dụng" (App Passwords) ở cuối trang hoặc tìm kiếm thanh tìm kiếm.
# 4. Chọn ứng dụng "Thư" (Mail) và thiết bị bất kỳ, bấm "Tạo" (Generate).
# 5. Copy mật khẩu gồm 16 ký tự viết liền (không dấu cách) và điền vào ô SMTP_PASSWORD dưới đây.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_16_character_app_password

# ── 6. Cấu hình Cloudinary (Lưu trữ ảnh cưới & sản phẩm) ──────────────────────
# Hướng dẫn lấy thông tin:
# 1. Đăng ký/Đăng nhập tài khoản tại https://cloudinary.com
# 2. Truy cập vào Dashboard (Trang điều khiển chính).
# 3. Copy các thông tin Cloud Name, API Key, và API Secret từ Dashboard rồi điền vào dưới đây.
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
